# Archivo de ejemplo para configuración del servidor
# Cópialo como ".env" antes de levantar los contenedores

# Base de Datos PostgreSQL
POSTGRES_USER=yeka_user
POSTGRES_PASSWORD=yeka_password_seguro
POSTGRES_DB=yeka

# Backend
JWT_SECRET=super_secret_jwt_key_aqui
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public
PORT=3000

# Frontend
# Reemplaza 'TU_IP_PUBLICA' con la IP real de tu servidor
VITE_API_URL=http://TU_IP_PUBLICA:3000
