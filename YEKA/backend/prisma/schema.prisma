generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Sede {
  id                 Int          @id @default(autoincrement())
  codigoSede         String       @unique
  nombre             String
  direccion          String?
  capacidadDiariaMax Int          @default(100)
  activa             Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  clientes           Cliente[]
  facturas           Factura[]
  inventarios        Inventario[]
  usuarios           Usuario[]
  anuncios           Anuncio[]
}

model Usuario {
  id            Int               @id @default(autoincrement())
  sedeId        Int
  nombre        String
  dni           String?           @unique
  telefono      String?
  email         String            @unique
  password      String
  pinAcceso     String?
  rol           Rol
  activo        Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  auditLogs     AuditLog[]
  prendasTaller Prenda[]          @relation("OperariaPrenda")
  jornadas      RegistroJornada[]
  sede          Sede              @relation(fields: [sedeId], references: [id])
  anunciosCreados Anuncio[]       @relation("AnuncioAdmin")
  anunciosLeidos  AnuncioRespuesta[] @relation("AnuncioUsuario")
}

model RegistroJornada {
  id        Int         @id @default(autoincrement())
  usuarioId Int
  tipo      TipoJornada
  timestamp DateTime    @default(now())
  usuario   Usuario     @relation(fields: [usuarioId], references: [id])
}

model Cliente {
  id                    Int       @id @default(autoincrement())
  sedeOrigenId          Int
  nombre                String
  dni                   String?
  celular               String?
  email                 String?
  nivelPremium          Int       @default(1)
  tallasMedidas         Json?
  preferenciasHistorial Json?
  activo                Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  sedeOrigen            Sede      @relation(fields: [sedeOrigenId], references: [id])
  facturas              Factura[]
}

model Factura {
  id               Int        @id @default(autoincrement())
  numero           String     @unique
  clienteId        Int?
  usuarioCreadorId Int
  sedeId           Int
  subtotal         Decimal    @default(0) @db.Decimal(10, 2)
  impuestosJson    Json?
  total            Decimal    @default(0) @db.Decimal(10, 2)
  estadoPago       EstadoPago @default(PENDIENTE)
  notas            String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  abonos           Abono[]
  cliente          Cliente?   @relation(fields: [clienteId], references: [id])
  sede             Sede       @relation(fields: [sedeId], references: [id])
  prendas          Prenda[]
}

model Abono {
  id         Int        @id @default(autoincrement())
  facturaId  Int
  monto      Decimal    @db.Decimal(10, 2)
  metodoPago MetodoPago
  notas      String?
  fecha      DateTime   @default(now())
  factura    Factura    @relation(fields: [facturaId], references: [id], onDelete: Cascade)
}

model TipoPrenda {
  id               Int              @id @default(autoincrement())
  nombre           String           @unique
  descripcion      String?
  activo           Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  preciosServicios PrecioServicio[]
  prendas          Prenda[]
}

model Prenda {
  id                      Int              @id @default(autoincrement())
  facturaId               Int
  codigoQR                String           @unique
  estadoActual            EstadoPrenda     @default(RECIBIDA)
  fechaCompromiso         DateTime?
  esLujo                  Boolean          @default(false)
  fotoUrl                 String?
  usuarioTallerId         Int?
  fechaUltimaNotificacion DateTime?
  notas                   String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  tipoPrendaId            Int
  color                   String
  marca                   String?
  talla                   String
  factura                 Factura          @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  tipoPrenda              TipoPrenda       @relation(fields: [tipoPrendaId], references: [id])
  usuarioTaller           Usuario?         @relation("OperariaPrenda", fields: [usuarioTallerId], references: [id])
  servicios               PrendaServicio[]
  tipoExpress             TipoExpress      @default(NORMAL)
}

model CatalogoServicio {
  id               Int              @id @default(autoincrement())
  categoria        String
  tipoEspecifico   String
  pesoPuntos       Int              @default(1)
  activo           Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  preciosServicios PrecioServicio[]
  asignaciones     PrendaServicio[]
}

model PrecioServicio {
  id                 Int              @id @default(autoincrement())
  catalogoServicioId Int
  tipoPrendaId       Int
  medidaBase         Decimal          @db.Decimal(10, 2)
  precioBase         Decimal          @db.Decimal(10, 2)
  medidaExtra        Decimal          @db.Decimal(10, 2)
  precioExtra        Decimal          @db.Decimal(10, 2)
  activo             Boolean          @default(true)
  catalogoServicio   CatalogoServicio @relation(fields: [catalogoServicioId], references: [id], onDelete: Cascade)
  tipoPrenda         TipoPrenda       @relation(fields: [tipoPrendaId], references: [id], onDelete: Cascade)

  @@unique([catalogoServicioId, tipoPrendaId])
}

model PrendaServicio {
  id              Int              @id @default(autoincrement())
  prendaId        Int
  servicioId      Int
  tipoExpress     TipoExpress      @default(NORMAL)
  precioFinal     Decimal          @db.Decimal(10, 2)
  createdAt       DateTime         @default(now())
  medidaEntregada Decimal?         @db.Decimal(10, 2)
  observaciones   String?
  prenda          Prenda           @relation(fields: [prendaId], references: [id], onDelete: Cascade)
  servicio        CatalogoServicio @relation(fields: [servicioId], references: [id])
}

model Inventario {
  id             Int      @id @default(autoincrement())
  sedeId         Int
  nombreInsumo   String
  unidad         String   @default("unidades")
  cantidadActual Decimal  @default(0) @db.Decimal(10, 2)
  puntoReorden   Decimal  @default(0) @db.Decimal(10, 2)
  updatedAt      DateTime @updatedAt
  sede           Sede     @relation(fields: [sedeId], references: [id])
}

model AuditLog {
  id              Int             @id @default(autoincrement())
  usuarioId       Int?
  accion          AccionAuditoria
  entidadAfectada String
  entidadId       Int?
  valorAnterior   Json?
  valorNuevo      Json?
  leido           Boolean         @default(false)
  timestamp       DateTime        @default(now())
  usuario         Usuario?        @relation(fields: [usuarioId], references: [id])
}

model Configuracion {
  id        Int      @id @default(autoincrement())
  clave     String   @unique
  valor     String
  updatedAt DateTime @updatedAt
}

enum Rol {
  ADMIN
  RECEPCION
  TALLER
}

enum EstadoPago {
  PENDIENTE
  PARCIAL
  PAGADO
  ANULADO
}

enum EstadoPrenda {
  RECIBIDA
  PENDIENTE_VALORACION
  EN_PRODUCCION
  ESPERANDO_PRUEBA
  PENDIENTE_RECOGIDA
  ENTREGADA
  PROPIEDAD_TALLER
}

enum TipoJornada {
  ENTRADA
  SALIDA
}

enum AccionAuditoria {
  CREACION
  MODIFICACION
  ANULACION
  CAMBIO_ESTADO
  ABONO
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
  BIZUM
}

enum TipoExpress {
  NORMAL
  EXPRESS_48H
  EXPRESS_24H
}

model Anuncio {
  id          Int      @id @default(autoincrement())
  sedeId      Int
  adminId     Int
  mensaje     String
  createdAt   DateTime @default(now())
  
  sede        Sede     @relation(fields: [sedeId], references: [id])
  admin       Usuario  @relation("AnuncioAdmin", fields: [adminId], references: [id])
  respuestas  AnuncioRespuesta[]
}

model AnuncioRespuesta {
  id          Int       @id @default(autoincrement())
  anuncioId   Int
  usuarioId   Int
  respuesta   String
  leidoAt     DateTime  @default(now())
  
  anuncio     Anuncio   @relation(fields: [anuncioId], references: [id], onDelete: Cascade)
  usuario     Usuario   @relation("AnuncioUsuario", fields: [usuarioId], references: [id])

  @@unique([anuncioId, usuarioId])
}
